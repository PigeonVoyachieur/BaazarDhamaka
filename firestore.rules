rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Les produits sont lisibles par tous (catalogue public).
    // L'écriture est ouverte pour faciliter le seed / l'ajout depuis le SDK.
    // ⚠️ À restreindre en production (auth admin, etc.).
    match /products/{product} {
      allow read: if true;
      allow write: if true;
    }
  }
}
