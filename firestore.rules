rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Les produits sont lisibles par tous (catalogue public).
    // L'écriture est ouverte pour faciliter le seed / l'ajout depuis le SDK.
    // ⚠️ À restreindre en production (auth admin, etc.).
    match /products/{product} {
      allow read: if true;
      allow write: if true;
    }

    // Commandes passées depuis la page panier.
    // Création ouverte pour permettre la commande sans authentification.
    // ⚠️ À restreindre en production (auth client, validation des montants, etc.).
    match /orders/{order} {
      allow read: if true;
      allow create: if true;
    }
  }
}
